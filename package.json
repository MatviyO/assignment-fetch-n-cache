    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "knip": "^6.3.1",
    "tailwindcss": "^4.2.2",
